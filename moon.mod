name = "ZSeanYves/MoonbitHTTP"

version = "0.5.0"

import {
  "moonbitlang/x@0.4.47",
  "moonbitlang/async@0.20.2",
}

readme = "README.md"

repository = "https://github.com/ZSeanYves/MoonbitHTTP"

license = "Apache-2.0"

keywords = [ "http", "http1", "http2", "protocol" ]

description = "Modular HTTP protocol codecs and connection utilities for MoonBit."

options(
  exclude: [ "_build", "target", ".mooncakes", ".DS_Store", "coverage.xml" ],
)
